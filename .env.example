# ─── Gateway ─────────────────────────────────────────────────────────────────
PORT=8080
ENV=development
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=gateway
DB_PASSWORD=gateway_secret
DB_NAME=ai_gateway
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

# ─── LLM Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# ─── Admin ───────────────────────────────────────────────────────────────────
# Change in production — used to protect /admin/* endpoints
ADMIN_TOKEN=change-me-in-production

# ─── Timeouts (seconds) ──────────────────────────────────────────────────────
UPSTREAM_TIMEOUT=60
SHUTDOWN_TIMEOUT=30
